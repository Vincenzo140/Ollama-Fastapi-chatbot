# Copy to .env and adjust as needed.

# --- API ---
APP_NAME=Ollama Chatbot API
DEBUG=false
HOST=0.0.0.0
PORT=8000

# --- Ollama ---
# Use http://ollama:11434 when running via docker-compose,
# or http://localhost:11434 when running Ollama on the host.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=300
DEFAULT_MODEL=gemma2:2b

# --- CORS (comma-separated origins, or * for all) ---
CORS_ORIGINS=*

# --- Storage ---
SQLITE_PATH=./data/chat.db
